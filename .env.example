# Copy this file to .env and fill in your real key.
# .env is git-ignored — it will NEVER be committed.
# Never put your real key directly in this file if this exact filename is tracked by git.

QWEN_API_KEY=your-qwen-cloud-api-key-here

# Optional — override default model tiering
QWEN_FAST_MODEL=qwen-plus
QWEN_REASONING_MODEL=qwen-max

# Optional — used by docker-compose / frontend to find the backend
API_BASE=http://localhost:8000
